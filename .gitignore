# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
alex_claw-*.tar

# Environment variables (contains secrets)
.env

# Giulia cache
.giulia/

# Local docs (specs, scripts, notes) — keep docs/screenshot/ for README images
/docs/*
!/docs/screenshot/

# Personal docker-compose variants (except swarm which is part of clustering)
docker-compose_*.yml
!docker-compose_swarm.yml

# Claude Code
.claude/
.mcp.json
TEST_RULES.md
TO-DO.md

# IDE
.elixir_ls/
.vscode/
.idea/

# Erlang
erl_crash.dump

# OS
.DS_Store
Thumbs.db

# Static assets (built from deps during Docker build)
priv/static/assets/

# Database backups and SQL dumps (may contain secrets)
*.sql
/backups/

# Python (web-automator)
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
