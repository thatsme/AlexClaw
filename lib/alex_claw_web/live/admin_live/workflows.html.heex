<div class="space-y-8">
  <div :if={@active_runs != %{}} class="bg-blue-900/20 border border-blue-800 rounded-lg p-4">
    <h3 class="text-sm font-semibold text-blue-300 mb-3">Active Runs</h3>
    <div :for={run <- Map.values(@active_runs)} class="flex items-center justify-between py-2 border-b border-blue-900/50 last:border-0">
      <div class="flex items-center gap-3">
        <span :if={run.status == :running} class="inline-block w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
        <span :if={run.status == :completed} class="inline-block w-2 h-2 rounded-full bg-green-400"></span>
        <span :if={run.status == :failed} class="inline-block w-2 h-2 rounded-full bg-red-400"></span>
        <span :if={run.status == :cancelled} class="inline-block w-2 h-2 rounded-full bg-gray-400"></span>
        <span class="text-sm text-white font-medium">{run.workflow_name}</span>
        <span class="text-xs text-gray-400">run #{run.run_id}</span>
        <span :if={run.current_step} class={[
          "text-xs",
          if(run.status == :completed, do: "text-green-300",
            else: if(run.status == :failed, do: "text-red-300",
              else: if(run.status == :cancelled, do: "text-gray-400", else: "text-blue-300")))
        ]}>
          {run.current_step}
        </span>
      </div>
      <button :if={run.status == :running}
        phx-click="cancel_run" phx-value-run-id={run.run_id}
        class="text-xs px-3 py-1 bg-red-900/60 hover:bg-red-800 text-red-300 rounded transition">
        Cancel
      </button>
    </div>
  </div>

  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-white">Workflows</h1>
    <div class="flex gap-2">
      <button phx-click="toggle_import_form" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded transition">
        {if @show_import_form, do: "Cancel Import", else: "Import Workflow"}
      </button>
      <button phx-click="toggle_form" class="px-4 py-2 bg-claw-700 hover:bg-claw-600 text-white text-sm rounded transition">
        {if @show_form && !@editing, do: "Cancel", else: "New Workflow"}
      </button>
    </div>
  </div>

  <div :if={@show_import_form} class="bg-gray-900 rounded-lg border border-gray-800 p-6">
    <h2 class="text-lg font-semibold text-white mb-4">Import Workflow</h2>
    <form id="import-workflow-form" phx-submit="import_workflow" phx-change="validate_import" class="space-y-4">
      <div class="flex items-center space-x-4">
        <label class="flex-1">
          <.live_file_input upload={@uploads.workflow_file}
            class="block w-full text-sm text-gray-400
              file:mr-4 file:py-2 file:px-4 file:rounded
              file:border-0 file:text-sm file:font-semibold
              file:bg-gray-800 file:text-gray-300
              hover:file:bg-gray-700 file:cursor-pointer" />
        </label>
      </div>
      <%= for entry <- @uploads.workflow_file.entries do %>
        <div class="flex items-center gap-3 text-sm text-gray-300">
          <span>{entry.client_name}</span>
          <span class="text-gray-500">({Float.round(entry.client_size / 1024, 1)} KB)</span>
          <button type="button" phx-click="cancel-upload" phx-value-ref={entry.ref}
            class="text-red-400 hover:text-red-300 text-xs">Remove</button>
        </div>
        <%= for err <- upload_errors(@uploads.workflow_file, entry) do %>
          <p class="text-red-400 text-sm">{upload_error_message(err)}</p>
        <% end %>
      <% end %>
      <button type="submit"
        disabled={@uploads.workflow_file.entries == []}
        class={[
          "px-4 py-2 text-sm rounded transition",
          if(@uploads.workflow_file.entries == [],
            do: "bg-gray-800 text-gray-600 cursor-not-allowed",
            else: "bg-claw-700 hover:bg-claw-600 text-white")
        ]}>
        Import Workflow
      </button>
    </form>
  </div>

  <div :if={@show_form && !@editing} class="bg-gray-900 rounded-lg border border-gray-800 p-6">
    <h2 class="text-lg font-semibold text-white mb-4">New Workflow</h2>
    <form phx-submit="save_workflow" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm text-gray-400 mb-1">Name <.tip text="Unique name for this workflow. Shown in the list, Telegram notifications, and run history." /></label>
        <input type="text" name="name" required
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm" />
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Schedule <.tip text="When to run this workflow automatically. Choose a preset or write a custom cron expression. Leave as Manual to run only on demand." /></label>
        <select name="schedule_preset" phx-change="schedule_changed"
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option :for={{cron, label} <- schedule_presets()} value={cron}>{label}</option>
        </select>
        <input :if={@custom_schedule} type="text" name="schedule_custom" placeholder="*/5 * * * *"
          class="w-full mt-2 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm font-mono" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm text-gray-400 mb-1">Description <.tip text="Optional description shown below the workflow name in the list." /></label>
        <input type="text" name="description"
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm" />
      </div>
      <div :if={length(@cluster_nodes) > 1}>
        <label class="block text-sm text-gray-400 mb-1">Run on <.tip text="Which node runs this workflow's schedule. Cluster-wide means any node can run it." /></label>
        <select name="node" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option value="">Cluster-wide</option>
          <option :for={n <- @cluster_nodes} value={n}>{n}</option>
        </select>
      </div>
      <input type="hidden" name="enabled" value="true" />
      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-gray-400">
          <input type="checkbox" name="requires_2fa" value="true" class="rounded bg-gray-800 border-gray-700" />
          Requires 2FA <.tip text="When enabled, running this workflow from Telegram requires a TOTP code for confirmation." />
        </label>
      </div>
      <div class="md:col-span-2">
        <button type="submit" class="px-4 py-2 bg-green-700 hover:bg-green-600 text-white text-sm rounded transition">Create</button>
      </div>
    </form>
  </div>

  <div :if={@editing} class="bg-gray-900 rounded-lg p-6 space-y-6" style="border: 3px solid rgba(14, 165, 233, 0.5);">
    <div class="flex justify-between items-center">
      <h2 class="text-lg font-semibold text-white">Editing: {@editing.name}</h2>
      <button phx-click="toggle_form" class="text-sm text-gray-400 hover:text-white">Close</button>
    </div>

    <form phx-submit="save_workflow" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm text-gray-400 mb-1">Name <.tip text="Unique name for this workflow. Shown in the list, Telegram notifications, and run history." /></label>
        <input type="text" name="name" required value={@editing.name}
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm" />
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Schedule <.tip text="When to run this workflow automatically. Choose a preset or write a custom cron expression. Leave as Manual to run only on demand." /></label>
        <select name="schedule_preset" phx-change="schedule_changed"
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option :for={{cron, label} <- schedule_presets()} value={cron}
            selected={if(@custom_schedule, do: cron == "custom", else: (@editing.schedule || "") == cron)}>
            {label}
          </option>
        </select>
        <input :if={@custom_schedule} type="text" name="schedule_custom" value={@editing.schedule || ""}
          class="w-full mt-2 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm font-mono"
          placeholder="*/5 * * * *" />
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Enabled <.tip text="Disabled workflows won't run on schedule and can't be triggered from Telegram. They can still be run manually from the admin UI." /></label>
        <select name="enabled" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option value="true" selected={@editing.enabled}>Yes</option>
          <option value="false" selected={!@editing.enabled}>No</option>
        </select>
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Description <.tip text="Optional description shown below the workflow name in the list." /></label>
        <input type="text" name="description" value={@editing.description || ""}
          class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm" />
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Default Provider <.tip text="LLM provider used by all steps unless overridden at the step level. Auto selects the best available." /></label>
        <select name="default_provider" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option :for={pc <- @provider_choices} value={pc.value} selected={(@editing.default_provider || "auto") == pc.value}>
            {pc.label}
          </option>
        </select>
      </div>
      <div :if={length(@cluster_nodes) > 1}>
        <label class="block text-sm text-gray-400 mb-1">Run on <.tip text="Which node runs this workflow's schedule. Cluster-wide means any node can run it." /></label>
        <select name="node" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm">
          <option value="" selected={is_nil(@editing.node) or @editing.node == ""}>Cluster-wide</option>
          <option :for={n <- @cluster_nodes} value={n} selected={@editing.node == n}>{n}</option>
        </select>
      </div>
      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-gray-400">
          <input type="checkbox" name="requires_2fa" value="true"
            checked={@editing.metadata["requires_2fa"] == true}
            class="rounded bg-gray-800 border-gray-700" />
          Requires 2FA <.tip text="When enabled, running this workflow from Telegram requires a TOTP code for confirmation." />
        </label>
      </div>
      <div class="flex items-end">
        <button type="submit" class="px-4 py-2 bg-green-700 hover:bg-green-600 text-white text-sm rounded transition">Save</button>
      </div>
    </form>

    <div>
      <h3 class="text-md font-semibold text-white mb-3">Steps</h3>
      <div class="space-y-2">
        <div :for={step <- @editing.steps} class="bg-gray-800 rounded overflow-hidden">
          <div class="p-3 flex items-center justify-between">
            <div class="flex items-center space-x-3 cursor-pointer" phx-click="edit_step" phx-value-id={step.id}>
              <span class="text-xs text-gray-500 font-mono w-6">{step.position}</span>
              <span class="text-sm text-white font-semibold">{step.name}</span>
              <span class={"text-xs px-2 py-0.5 rounded #{if step.skill in @available_skills, do: "bg-gray-700 text-claw-500", else: "bg-red-900/50 text-red-400"}"}>{step.skill}{if step.skill not in @available_skills, do: " (missing)", else: ""}</span>
              <span :if={step.llm_tier} class="text-xs px-2 py-0.5 rounded bg-gray-700 text-yellow-400">{step.llm_tier}</span>
              <span :if={step.llm_model && step.llm_model != "" && step.llm_model != "auto"} class="text-xs px-2 py-0.5 rounded bg-gray-700 text-green-400">{step.llm_model}</span>
              <span :if={step.prompt_template} class="text-xs text-gray-600">has prompt</span>
              <span :if={step.input_from} class="text-xs px-2 py-0.5 rounded bg-gray-700 text-orange-400">input from step {step.input_from}</span>
              <span :for={route <- step.routes || []} class="text-xs px-2 py-0.5 rounded bg-gray-700 text-purple-400">{route["branch"]}→{route["goto"]}</span>
            </div>
            <div class="flex items-center space-x-2">
              <button phx-click="edit_step" phx-value-id={step.id}
                class="text-xs text-claw-500 hover:text-claw-400">{if @editing_step && @editing_step.id == step.id, do: "Close", else: "Edit"}</button>
              <button phx-click="move_step_up" phx-value-id={step.id} class="text-xs text-gray-400 hover:text-white">Up</button>
              <button phx-click="move_step_down" phx-value-id={step.id} class="text-xs text-gray-400 hover:text-white">Down</button>
              <button phx-click="remove_step" phx-value-id={step.id}
                data-confirm="Remove this step?"
                class="text-xs text-red-500 hover:text-red-400">Remove</button>
            </div>
          </div>

          <div :if={@editing_step && @editing_step.id == step.id} class="border-t border-gray-700 p-4 bg-gray-850">
            <form phx-submit="save_step" class="space-y-3">
              <div class={["grid grid-cols-1 gap-3", if(skill_has_field?(@editing_step.skill, :llm_tier), do: "md:grid-cols-4", else: "md:grid-cols-2")]}>
                <div>
                  <label class="block text-xs text-gray-500 mb-1">Step Name <.tip text="Display name for this step in the workflow." /></label>
                  <input type="text" name="step_name" required value={@editing_step.name}
                    class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm" />
                </div>
                <div>
                  <label class="block text-xs text-gray-500 mb-1">Skill <.tip text="Which skill to execute at this step. Core skills are built-in, dynamic skills are loaded from .ex files." /></label>
                  <select name="step_skill" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option :if={@editing_step.skill not in @available_skills} value={@editing_step.skill} selected class="text-red-400">{@editing_step.skill} (missing)</option>
                    <option :for={s <- @available_skills} value={s} selected={@editing_step.skill == s}>{s}{if s in @dynamic_skills, do: " (dynamic)", else: ""}</option>
                  </select>
                </div>
                <div :if={skill_has_field?(@editing_step.skill, :llm_tier)}>
                  <label class="block text-xs text-gray-500 mb-1">LLM Tier <.tip text="Reasoning tier: light (fast/cheap), medium (balanced), heavy (deep reasoning), local (on-device model)." /></label>
                  <select name="step_llm_tier" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option value="" selected={!@editing_step.llm_tier}>None</option>
                    <option :for={t <- @llm_tiers} value={t} selected={@editing_step.llm_tier == t}>{t}</option>
                  </select>
                </div>
                <div :if={skill_has_field?(@editing_step.skill, :llm_model)}>
                  <label class="block text-xs text-gray-500 mb-1">Provider <.tip text="Which LLM provider to use. Auto selects the best available based on tier." /></label>
                  <select name="step_llm_model" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option :for={pc <- @provider_choices} value={pc.value} selected={(@editing_step.llm_model || "auto") == pc.value}>
                      {pc.label}
                    </option>
                  </select>
                </div>
              </div>
              <div :if={@editing_step.position > 1}>
                <label class="block text-xs text-gray-500 mb-1">
                  Input from <.tip text="Which step's output to use as input. Default: previous step. Override to create branching workflows." />
                </label>
                <select name="step_input_from" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                  <option value="" selected={!@editing_step.input_from}>Previous step (default)</option>
                  <option :for={s <- Enum.filter(@editing.steps, &(&1.position < @editing_step.position))}
                    value={s.position} selected={@editing_step.input_from == s.position}>
                    Step {s.position}: {s.name}
                  </option>
                </select>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div>
                  <label class="block text-xs text-gray-500 mb-1">
                    On Circuit Open <.tip text="What to do when the circuit breaker is open (skill failing repeatedly). Halt stops the workflow. Skip passes the input to the next step." />
                  </label>
                  <select name="step_on_circuit_open" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option value="halt" selected={get_in(@editing_step.config, ["on_circuit_open"]) != "skip" and get_in(@editing_step.config, ["on_circuit_open"]) != "fallback"}>Halt workflow</option>
                    <option value="skip" selected={get_in(@editing_step.config, ["on_circuit_open"]) == "skip"}>Skip step</option>
                    <option value="fallback" selected={get_in(@editing_step.config, ["on_circuit_open"]) == "fallback"}>Fallback skill</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs text-gray-500 mb-1">
                    On Missing Skill <.tip text="What to do when the skill is not loaded (e.g. dynamic skill unloaded). Halt stops the workflow. Skip passes the input to the next step." />
                  </label>
                  <select name="step_on_missing_skill" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option value="halt" selected={get_in(@editing_step.config, ["on_missing_skill"]) != "skip"}>Halt workflow</option>
                    <option value="skip" selected={get_in(@editing_step.config, ["on_missing_skill"]) == "skip"}>Skip step</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs text-gray-500 mb-1">Fallback Skill <.tip text="Alternative skill to run when the primary skill's circuit is open. Only used when On Circuit Open is set to Fallback." /></label>
                  <select name="step_fallback_skill" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                    <option value="">None</option>
                    <option :for={s <- @available_skills} value={s} selected={get_in(@editing_step.config, ["fallback_skill"]) == s}>{s}</option>
                  </select>
                </div>
              </div>
              <div :if={skill_has_field?(@editing_step.skill, :prompt_template)}>
                <div class="flex items-center justify-between mb-1">
                  <label class="text-xs text-gray-500">
                    Prompt Template <.tip text={skill_help(@editing_step.skill).prompt} />
                  </label>
                  <div :if={skill_has_prompt_scaffolds?(@editing_step.skill)} class="flex gap-1">
                    <button :for={{label, _text} <- skill_prompt_scaffolds(@editing_step.skill)}
                      type="button" phx-click="scaffold_prompt" phx-value-scaffold={label}
                      class="text-xs px-2 py-0.5 bg-gray-700 hover:bg-gray-600 text-claw-400 rounded transition">
                      {label}
                    </button>
                  </div>
                </div>
                <textarea name="step_prompt_template" rows="5"
                  placeholder="Use {input} for previous step output, {resources} for assigned resources, {context} for step config context"
                  class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm font-mono">{@editing_step.prompt_template || ""}</textarea>
              </div>
              <div :if={skill_has_field?(@editing_step.skill, :config)}>
                <div class="flex items-center justify-between mb-1">
                  <label class="text-xs text-gray-500">
                    Config (JSON) <.tip text={skill_help(@editing_step.skill).config} />
                  </label>
                  <div class="flex gap-1">
                    <button :if={!skill_has_scaffolds?(@editing_step.skill)} type="button" phx-click="scaffold_config"
                      class="text-xs px-2 py-0.5 bg-gray-700 hover:bg-gray-600 text-claw-400 rounded transition">
                      Scaffold
                    </button>
                    <button :for={{label, _json} <- skill_scaffolds(@editing_step.skill)}
                      type="button" phx-click="scaffold_config_named" phx-value-scaffold={label}
                      class="text-xs px-2 py-0.5 bg-gray-700 hover:bg-gray-600 text-claw-400 rounded transition">
                      {label}
                    </button>
                  </div>
                </div>
                <textarea name="step_config" rows="4"
                  placeholder={skill_config_hint(@editing_step.skill)}
                  class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm font-mono">{format_config(@editing_step.config)}</textarea>
              </div>
              <div>
                <label class="block text-xs text-gray-500 mb-2">
                  Routes <.tip text="Conditional branching: for each branch the skill can return, choose which step to go to next. Leave as 'Next step' for linear flow." />
                </label>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
                  <div :for={branch <- routes_for_skill(@editing_step.skill)}>
                    <label class="block text-xs text-gray-600 mb-0.5">{branch}</label>
                    <select name={"route_#{branch}"} class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                      <option value="" selected={route_target(@editing_step, to_string(branch)) == nil}>Next step (default)</option>
                      <option :for={s <- @editing.steps} value={s.position}
                        selected={route_target(@editing_step, to_string(branch)) == s.position}>
                        Step {s.position}: {s.name}
                      </option>
                      <option value="end" selected={route_target(@editing_step, to_string(branch)) == "end"}>End workflow</option>
                    </select>
                  </div>
                </div>
              </div>
              <div class="flex space-x-2">
                <button type="submit" class="px-3 py-1.5 bg-green-700 hover:bg-green-600 text-white text-sm rounded transition">Save Step</button>
                <button type="button" phx-click="cancel_edit_step" class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded transition">Cancel</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <form :if={!@adding_step} phx-change="begin_add_step" class="mt-3 flex items-end gap-2">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Add Step</label>
          <select name="skill" class="bg-gray-800 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
            <option value="">Select skill...</option>
            <option :for={s <- @available_skills} value={s}>{s}{if s in @dynamic_skills, do: " (dynamic)", else: ""}</option>
          </select>
        </div>
      </form>

      <div :if={@adding_step} class="mt-3 bg-gray-800 rounded border border-gray-700 p-4">
        <div class="flex items-center justify-between mb-3">
          <h4 class="text-sm font-semibold text-white">New Step — <span class="text-claw-500">{@adding_step}</span></h4>
          <button type="button" phx-click="cancel_add_step" class="text-xs text-gray-400 hover:text-white">Cancel</button>
        </div>
        <form phx-submit="add_step" class="space-y-3">
          <input type="hidden" name="step_skill" value={@adding_step} />
          <div class={["grid grid-cols-1 gap-3", if(skill_has_field?(@adding_step, :llm_tier), do: "md:grid-cols-4", else: "md:grid-cols-2")]}>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Step Name <.tip text="Display name for this step in the workflow." /></label>
              <input type="text" name="step_name" required
                class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Skill <.tip text="Which skill to execute at this step. Core skills are built-in, dynamic skills are loaded from .ex files." /></label>
              <input type="text" disabled value={@adding_step}
                class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-gray-400 text-sm" />
            </div>
            <div :if={skill_has_field?(@adding_step, :llm_tier)}>
              <label class="block text-xs text-gray-500 mb-1">LLM Tier <.tip text="Reasoning tier: light (fast/cheap), medium (balanced), heavy (deep reasoning), local (on-device model)." /></label>
              <select name="step_llm_tier" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                <option value="">None</option>
                <option :for={t <- @llm_tiers} value={t}>{t}</option>
              </select>
            </div>
            <div :if={skill_has_field?(@adding_step, :llm_model)}>
              <label class="block text-xs text-gray-500 mb-1">Provider <.tip text="Which LLM provider to use. Auto selects the best available based on tier." /></label>
              <select name="step_llm_model" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                <option :for={pc <- @provider_choices} value={pc.value}>{pc.label}</option>
              </select>
            </div>
          </div>
          <div :if={@editing && length(@editing.steps) > 0}>
            <label class="block text-xs text-gray-500 mb-1">
              Input from <.tip text="Which step's output to use as input. Default: previous step. Override to create branching workflows." />
            </label>
            <select name="step_input_from" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
              <option value="">Previous step (default)</option>
              <option :for={s <- @editing.steps} value={s.position}>
                Step {s.position}: {s.name}
              </option>
            </select>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-500 mb-1">On Circuit Open <.tip text="What to do when the circuit breaker is open (skill failing repeatedly). Halt stops the workflow. Skip passes the input to the next step." /></label>
              <select name="step_on_circuit_open" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                <option value="halt">Halt workflow</option>
                <option value="skip">Skip step</option>
                <option value="fallback">Fallback skill</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">On Missing Skill <.tip text="What to do when the skill is not loaded (e.g. dynamic skill unloaded). Halt stops the workflow. Skip passes the input to the next step." /></label>
              <select name="step_on_missing_skill" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                <option value="halt">Halt workflow</option>
                <option value="skip">Skip step</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Fallback Skill <.tip text="Alternative skill to run when the primary skill's circuit is open. Only used when On Circuit Open is set to Fallback." /></label>
              <select name="step_fallback_skill" class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                <option value="">None</option>
                <option :for={s <- @available_skills} value={s}>{s}</option>
              </select>
            </div>
          </div>
          <div :if={skill_has_field?(@adding_step, :prompt_template)}>
            <div class="flex items-center justify-between mb-1">
              <label class="text-xs text-gray-500">
                Prompt Template <.tip text={skill_help(@adding_step).prompt} />
              </label>
              <div :if={skill_has_prompt_scaffolds?(@adding_step)} class="flex gap-1">
                <button :for={{label, _text} <- skill_prompt_scaffolds(@adding_step)}
                  type="button" phx-click="set_add_prompt_scaffold" phx-value-scaffold={label}
                  class="text-xs px-2 py-0.5 bg-gray-700 hover:bg-gray-600 text-claw-400 rounded transition">
                  {label}
                </button>
              </div>
            </div>
            <textarea name="step_prompt_template" rows="4"
              placeholder="Use {input} for previous step output"
              class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm font-mono">{@adding_step_prompt || ""}</textarea>
          </div>
          <div :if={skill_has_field?(@adding_step, :config)}>
            <div class="flex items-center justify-between mb-1">
              <label class="text-xs text-gray-500">
                Config (JSON) <.tip text={skill_help(@adding_step).config} />
              </label>
              <div :if={skill_has_scaffolds?(@adding_step)} class="flex gap-1">
                <button :for={{label, _json} <- skill_scaffolds(@adding_step)}
                  type="button" phx-click="set_add_scaffold" phx-value-scaffold={label}
                  class="text-xs px-2 py-0.5 bg-gray-700 hover:bg-gray-600 text-claw-400 rounded transition">
                  {label}
                </button>
              </div>
            </div>
            <textarea name="step_config" rows="3"
              placeholder={skill_config_hint(@adding_step)}
              class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm font-mono">{@adding_step_config || skill_config_scaffold(@adding_step)}</textarea>
          </div>
          <div :if={@editing}>
            <label class="block text-xs text-gray-500 mb-2">
              Routes <.tip text="Conditional branching: for each branch the skill can return, choose which step to go to next. Leave as 'Next step' for linear flow." />
            </label>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2">
              <div :for={branch <- routes_for_skill(@adding_step)}>
                <label class="block text-xs text-gray-600 mb-0.5">{branch}</label>
                <select name={"route_#{branch}"} class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
                  <option value="">Next step (default)</option>
                  <option :for={s <- @editing.steps} value={s.position}>
                    Step {s.position}: {s.name}
                  </option>
                  <option value="end">End workflow</option>
                </select>
              </div>
            </div>
          </div>
          <div class="flex space-x-2">
            <button type="submit" class="px-3 py-1.5 bg-green-700 hover:bg-green-600 text-white text-sm rounded transition">Save Step</button>
            <button type="button" phx-click="cancel_add_step" class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded transition">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <div :if={workflow_uses_resources?(@editing)}>
      <h3 class="text-md font-semibold text-white mb-3">Assigned Resources</h3>
      <div class="space-y-1 mb-3">
        <div :for={wr <- @editing.workflow_resources} class="bg-gray-800 rounded p-2 flex items-center justify-between">
          <span class="text-sm text-white">{find_resource_name(@all_resources, wr.resource_id)}</span>
          <div class="flex items-center space-x-2">
            <span class="text-xs text-gray-500">{wr.role}</span>
            <button phx-click="unassign_resource" phx-value-resource_id={wr.resource_id}
              class="text-xs text-red-500 hover:text-red-400">Remove</button>
          </div>
        </div>
        <p :if={@editing.workflow_resources == []} class="text-sm text-gray-500">No resources assigned</p>
      </div>
      <div class="flex items-center space-x-2">
        <form phx-submit="assign_resource" class="flex items-center space-x-2">
          <select name="resource_id" class="bg-gray-800 border border-gray-700 rounded px-2 py-1.5 text-white text-sm">
            <option :for={r <- unassigned_resources(@all_resources, @editing.workflow_resources)} value={r.id}>
              {r.name} ({r.type})
            </option>
          </select>
          <button type="submit" class="px-3 py-1.5 bg-claw-700 hover:bg-claw-600 text-white text-sm rounded transition">
            Assign
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="bg-gray-900 rounded-lg border border-gray-800 overflow-hidden">
    <table class="w-full table-fixed">
      <thead class="bg-gray-800">
        <tr>
          <th class="w-2/5 px-4 py-3 text-left text-xs text-gray-400 uppercase">Name</th>
          <th class="w-1/6 px-4 py-3 text-left text-xs text-gray-400 uppercase">Schedule</th>
          <th class="w-14 px-4 py-3 text-left text-xs text-gray-400 uppercase">Steps</th>
          <th class="w-20 px-4 py-3 text-left text-xs text-gray-400 uppercase">Status</th>
          <th class="w-14 px-4 py-3 text-left text-xs text-gray-400 uppercase">Runs</th>
          <th class="px-4 py-3 text-right text-xs text-gray-400 uppercase">Actions</th>
        </tr>
        <tr>
          <th class="px-4 pb-2">
            <form phx-change="filter_name">
              <input type="text" name="name_filter" value={@name_filter} placeholder="Filter by name..."
                phx-debounce="200"
                class="w-full bg-gray-900 border border-gray-700 rounded px-2 py-1 text-white text-xs placeholder-gray-600" />
            </form>
          </th>
          <th colspan="5"></th>
        </tr>
      </thead>
      <tbody>
        <tr :if={@workflows == []} class="border-t border-gray-800">
          <td colspan="6" class="px-4 py-8 text-center text-gray-500">No workflows yet</td>
        </tr>
        <tr :for={wf <- filter_workflows(@workflows, @name_filter)} class="border-t border-gray-800">
          <td class="px-4 py-3">
            <div class="text-sm font-semibold text-white truncate">
              {wf.name}
              <span :if={workflow_cluster_role(wf.id) == :receiver} class="ml-1 text-xs px-1.5 py-0.5 rounded bg-purple-900/50 text-purple-300" title="Receives data from remote nodes">recv</span>
              <span :if={workflow_cluster_role(wf.id) == :sender} class="ml-1 text-xs px-1.5 py-0.5 rounded bg-blue-900/50 text-blue-300" title="Sends data to remote nodes">send</span>
              <span :if={workflow_cluster_role(wf.id) == :bridge} class="ml-1 text-xs px-1.5 py-0.5 rounded bg-amber-900/50 text-amber-300" title="Receives and sends data across nodes">bridge</span>
            </div>
            <div class="flex items-center gap-1">
              <span :if={wf.description} class="text-xs text-gray-500 break-words">{wf.description}</span>
              <span :if={wf.node && wf.node != ""} class="text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-400 font-mono" title={"Pinned to #{wf.node}"}>{wf.node}</span>
            </div>
          </td>
          <td class="px-4 py-3 text-sm text-gray-400">
            <span>{schedule_label(wf.schedule)}</span>
            <span :if={wf.schedule && !schedule_is_preset?(wf.schedule)} class="text-xs text-gray-600 font-mono ml-1">({wf.schedule})</span>
          </td>
          <td class="px-4 py-3 text-sm text-gray-400">{length(load_steps(wf.id))}</td>
          <td class="px-4 py-3">
            <span :if={wf.enabled} class="text-xs px-2 py-1 rounded bg-green-900 text-green-300">enabled</span>
            <span :if={!wf.enabled} class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-500">disabled</span>
          </td>
          <td class="px-4 py-3 text-sm text-gray-400">{count_runs(wf.id)}</td>
          <td class="px-4 py-3 text-right whitespace-nowrap">
            <div class="flex items-center justify-end gap-1">
              <button phx-click="run_now" phx-value-id={wf.id}
                class="text-xs px-2 py-1 rounded bg-green-900/60 hover:bg-green-800 text-green-300 transition">Run</button>
              <a href={"/workflows/#{wf.id}/runs"}
                class="text-xs px-2 py-1 rounded bg-gray-800 hover:bg-gray-700 text-gray-300 transition">Runs</a>
              <a href={"/workflows/#{wf.id}/export"}
                class="text-xs px-2 py-1 rounded bg-blue-900/60 hover:bg-blue-800 text-blue-300 transition">Export</a>
              <button phx-click="duplicate" phx-value-id={wf.id}
                class="text-xs px-2 py-1 rounded bg-yellow-900/60 hover:bg-yellow-800 text-yellow-300 transition">Clone</button>
              <button phx-click="edit" phx-value-id={wf.id}
                class="text-xs px-2 py-1 rounded bg-claw-900/60 hover:bg-claw-800 text-claw-300 transition">Edit</button>
              <button phx-click="delete" phx-value-id={wf.id}
                data-confirm="Delete this workflow and all its steps?"
                class="text-xs px-2 py-1 rounded bg-red-900/60 hover:bg-red-800 text-red-300 transition">Del</button>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
